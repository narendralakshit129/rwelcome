<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!--  Gradient background  -->
    <item>
        <shape>
            <gradient
                android:angle="0"
                android:endColor="#5CB5E0"
                android:startColor="#ffffff" />
        </shape>
    </item>
    <!--  Image overlay  -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/splash"
            android:tileMode="disabled" />
    </item>
</layer-list>