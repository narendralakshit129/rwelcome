<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Transparent background -->
    <solid android:color="@android:color/transparent"/>

    <!-- Dotted border -->
    <stroke
        android:width="1dp"
        android:color="#B0B0B0"
        android:dashWidth="6dp"
        android:dashGap="4dp"/>

    <!-- Rounded corners -->
    <corners android:radius="6dp"/>
</shape>


