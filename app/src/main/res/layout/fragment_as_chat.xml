<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    tools:context=".fragment.AsChatFragment">

    <!-- TODO: Update blank fragment layout -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="200dp">


        <androidx.cardview.widget.CardView
            android:layout_alignParentTop="true"
            android:id="@+id/layout_top_message"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            app:cardCornerRadius="2dp"
            app:cardElevation="15dp"
            app:cardBackgroundColor="@android:color/white">

            <TextView
                android:gravity="center|start"
                android:id="@+id/tvUserName"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Message"
                android:paddingStart="10dp"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/layout_tabs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/layout_top_message"
            android:background="@color/white"
            android:gravity="center|start"
            android:orientation="horizontal"
            android:padding="10dp"
            android:weightSum="4">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_above="@+id/layout_follow_following"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <!-- Avatar -->
                <ImageView
                    android:id="@+id/friends_image"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/circle_bg"
                    android:scaleType="centerCrop"
                    android:src="@drawable/friends" />

                <TextView
                    android:gravity="center"
                    android:layout_marginTop="4dp"
                    android:id="@+id/txt_friends"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Friends"
                    android:textColor="@color/blue"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_above="@+id/layout_follow_following"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <!-- Avatar -->
                <ImageView
                    android:id="@+id/friends_image"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/circle_bg"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bell_icon" />

                <TextView
                    android:id="@+id/txt_friends"
                    android:gravity="center"
                    android:layout_marginTop="4dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Notification"
                    android:textColor="@color/gray"
                    android:textSize="14sp"
                    android:textStyle="normal" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_above="@+id/layout_follow_following"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <!-- Avatar -->
                <ImageView
                    android:id="@+id/friends_image"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/circle_bg"
                    android:scaleType="centerCrop"
                    android:src="@drawable/system_icon" />

                <TextView
                    android:gravity="center"
                    android:layout_marginTop="4dp"
                    android:id="@+id/txt_friends"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="System"
                    android:textColor="@color/gray"
                    android:textSize="14sp"
                    android:textStyle="normal" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_above="@+id/layout_follow_following"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <!-- Avatar -->
                <ImageView
                    android:id="@+id/friends_image"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/circle_bg"
                    android:scaleType="centerCrop"
                    android:src="@drawable/family_icon" />

                <TextView
                    android:gravity="center"
                    android:layout_marginTop="4dp"
                    android:id="@+id/txt_friends"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Family"
                    android:textColor="@color/gray"
                    android:textSize="14sp"
                    android:textStyle="normal" />

            </LinearLayout>

        </LinearLayout>


        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_alignParentBottom="true"
            android:background="#EEEEEE" />

    </RelativeLayout>

</FrameLayout>