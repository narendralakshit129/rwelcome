<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="90dp"
    android:layout_margin="2dp"
    app:cardCornerRadius="2dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@android:color/white">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="10dp">

        <!-- Rank Number -->
        <TextView
            android:id="@+id/tv_rank"
            android:layout_width="30dp"
            android:layout_height="match_parent"
            android:text="1"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#3FA9F5"
            android:gravity="center" />

        <!-- User Image -->


        <com.google.android.material.imageview.ShapeableImageView
            android:layout_centerInParent="true"
            android:id="@+id/img_user"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:scaleType="centerCrop"
            android:layout_toEndOf="@id/tv_rank"
            android:src="@mipmap/user_profiles"
            app:shapeAppearanceOverlay="@style/CircleImageView" />


        <!-- Username -->
        <TextView
            android:id="@+id/tv_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/img_user"
            android:layout_marginStart="10dp"
            android:text="ZEHER"
            android:textSize="13sp"
            android:textStyle="normal|italic|bold"
            android:textColor="@android:color/black" />

        <!-- Badges Row -->
        <LinearLayout
            android:id="@+id/layoutBadges"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_user_name"
            android:layout_toEndOf="@id/img_user"
            android:layout_marginStart="10dp"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Flag -->
            <ImageView
                android:id="@+id/imgFlag"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/india_icon" />

            <!-- Chat Badge -->
            <TextView
                android:id="@+id/badgeChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Chat"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:background="@drawable/bg_badge_green" />

            <!-- Diamond Badge -->
            <TextView
                android:id="@+id/badgeDiamond"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Diamond"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:background="@drawable/bg_badge_purple" />



        </LinearLayout>

        <!-- Level Badge -->
        <TextView
            android:layout_toEndOf="@id/img_user"
            android:layout_below="@id/layoutBadges"
            android:id="@+id/badgeLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginTop="6dp"
            android:text="Lv.101"
            android:textSize="11sp"
            android:textColor="@android:color/white"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:background="@drawable/bg_badge_orange" />

        <!-- Coins -->
        <TextView
            android:id="@+id/tv_coins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="134.5M"
            android:textStyle="bold"
            android:textColor="#3FA9F5"
            android:textSize="14sp" />

        <!-- Coin Icon -->
        <ImageView
            android:id="@+id/imgCoin"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_toStartOf="@id/tv_coins"
            android:layout_marginEnd="5dp"
            android:src="@drawable/coin_icon" />

        <!-- Small Stats Icon -->

    </RelativeLayout>

</androidx.cardview.widget.CardView>
