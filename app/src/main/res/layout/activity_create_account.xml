    <TextView
        android:id="@+id/txt_nationality"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="@string/txt_nationality"
        android:textColor="#000"
        android:textSize="16sp"
        android:textStyle="normal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llFemale" />

    <TextView
        android:gravity="center|start"
        android:id="@+id/tvNationality"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="India"
        android:drawableEnd="@drawable/ic_arrow_down"
        android:background="@drawable/bg_otp"
        app:layout_constraintTop_toBottomOf="@id/txt_nationality"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />




    <TextView
        android:id="@+id/txt_your_bio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="@string/txt_enter_your_bio"
        android:textColor="#000"
        android:textSize="16sp"
        android:textStyle="normal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvNationality" />

    <EditText
        android:id="@+id/et_tilBio"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_otp"
        android:drawablePadding="5dp"
        android:fillColor="?attr/colorControlNormal"
        android:gravity="center|start"
        android:inputType="text"
        android:textColor="@color/black"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_your_bio" />



    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_create_profile"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="#29B6F6"
        android:text="@string/txt_create_profile"
        android:textColor="@android:color/white"
        android:textSize="16dp"
        app:cornerRadius="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_tilBio" />


</androidx.constraintlayout.widget.ConstraintLayout>