<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="5dp"
    android:layout_marginHorizontal="2dp"
    android:background="@color/white"
    app:cardCornerRadius="5dp"
    app:cardElevation="4dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/blue_light"
        android:paddingVertical="4dp">

        <!-- Rank Number -->
        <TextView
            android:id="@+id/tv_rank"
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:text="11"
            android:textColor="@color/blue"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Left Profile -->
        <LinearLayout
            android:id="@+id/layoutUser1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_toRightOf="@+id/tv_rank"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Left Profile Image -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/image_user_first"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:scaleType="centerCrop"
                android:src="@mipmap/user_profiles"
                app:shapeAppearanceOverlay="@style/CircleImageView" />

            <!-- Left Username -->
            <TextView
                android:id="@+id/txt_name_first"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="KARAN"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textStyle="normal|italic|bold" />

        </LinearLayout>


        <!-- Heart Icon Center -->
        <ImageView
            android:id="@+id/imgHeart"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_centerInParent="true"
            android:src="@drawable/heart_butterfly" />

        <!-- Right Profile -->


        <LinearLayout
            android:id="@+id/layoutUser2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toLeftOf="@+id/tv_coins"
            android:gravity="center"
            android:orientation="vertical">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/image_user_second"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:scaleType="centerCrop"
                android:src="@mipmap/user_profiles"
                app:shapeAppearanceOverlay="@style/CircleImageView" />

            <TextView
                android:id="@+id/txt_name_second"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="PREET"
                android:textColor="@android:color/black"
                android:textSize="13sp"
                android:textStyle="normal|italic|bold" />

        </LinearLayout>

        <!-- Coin Text -->
        <TextView
            android:id="@+id/tv_coins"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:text="13.4B"
            android:textColor="@color/blue"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Crown Icon (Optional for Top Rank) -->
        <!-- <ImageView
             android:id="@+id/imgCrown"
             android:layout_width="20dp"
             android:layout_height="20dp"
             android:layout_alignParentEnd="true"
             android:layout_marginTop="5dp"
             android:src="@drawable/ic_crown"
             android:visibility="gone" />-->

    </RelativeLayout>

</androidx.cardview.widget.CardView>
