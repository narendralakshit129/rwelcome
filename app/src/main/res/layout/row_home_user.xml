<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    android:background="@android:color/white"
    android:gravity="center"
    android:padding="10dp">

    <!-- Profile -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/image_avatar"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/circle_bg"
        android:scaleType="centerCrop"
        android:src="@mipmap/user_profiles"
        app:shapeAppearanceOverlay="@style/CircleImageView" />


    <!-- Name -->
    <TextView
        android:id="@+id/txt_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@id/image_avatar"
        android:text="India coin seller"
        android:textColor="#222"
        android:textSize="16sp"
        android:layout_marginBottom="4dp"
        android:textStyle="bold" />

    <!-- Country Flag -->
    <ImageView
        android:id="@+id/imgFlag"
        android:layout_width="22dp"
        android:layout_height="20dp"
        android:layout_below="@id/txt_name"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@id/image_avatar"
        android:src="@drawable/india_icon" />

    <!-- Chat -->
    <TextView
        android:id="@+id/badgeChat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/txt_name"
        android:layout_marginStart="6dp"
        android:layout_toEndOf="@id/imgFlag"
        android:background="@drawable/bg_badge_green"
        android:gravity="center"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:text="Chat"
        android:textColor="@android:color/white"
        android:textSize="12sp" />

    <!-- Level -->
    <TextView
        android:id="@+id/txt_level"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/txt_name"
        android:layout_marginStart="6dp"
        android:layout_toEndOf="@id/badgeChat"
        android:background="@drawable/bg_badge_orange"
        android:gravity="center"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:text="Lv. 101"
        android:textColor="@android:color/white"
        android:textSize="12sp" />

    <!-- Diamond -->
    <TextView
        android:id="@+id/txt_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/txt_name"
        android:layout_marginStart="6dp"
        android:layout_toEndOf="@id/txt_level"
        android:background="@drawable/bg_badge_purple"
        android:gravity="center"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:text="Diamond"
        android:textColor="@android:color/white"
        android:textSize="12sp" />

    <!-- Shield Rank -->
    <FrameLayout
        android:id="@+id/layoutShield"
        android:layout_width="32dp"
        android:layout_height="35dp"
        android:layout_below="@+id/imgFlag"
        android:layout_alignParentBottom="true"
        android:layout_margin="5dp"
        android:background="@drawable/shield"
        android:layout_toEndOf="@id/image_avatar">

      <!--  <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/shield" />-->

        <TextView
            android:id="@+id/txtRank"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="12"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Equalizer Icon -->
    <ImageView
        android:id="@+id/imgEqualizer"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:src="@drawable/baseline_equalizer_24" />

    <!-- Voice Count -->
    <TextView
        android:id="@+id/txtVoiceCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginEnd="4dp"
        android:layout_toStartOf="@id/imgEqualizer"
        android:text="1"
        android:textColor="#444"
        android:textStyle="bold" />

</RelativeLayout>


