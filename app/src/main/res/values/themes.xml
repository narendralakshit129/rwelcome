<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.RWelocme" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="android:windowBackground">@color/transparent</item>
    </style>

    <style name="Theme.RWelocme" parent="Base.Theme.RWelocme" />



    <style name="Theme.RWelocme.Splash" parent="Theme.SplashScreen">

        <!-- Fullscreen -->
        <item name="android:windowFullscreen">true</item>
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Prevent layout issues -->
        <item name="android:fitsSystemWindows">true</item>
        
        <!-- App theme after splash -->
        <item name="postSplashScreenTheme">@style/Theme.RWelocme</item>

    </style>


    <style name="OtpBox">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:gravity">center</item>
        <item name="android:inputType">number</item>
        <item name="android:maxLength">1</item>
        <item name="android:textSize">18sp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/bg_otp</item>
    </style>

    <style name="CircleImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="TabText">
        <item name="android:textColor">#999999</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TabTextSelected">
        <item name="android:textColor">#2E7BFF</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>


    <style name="GoldenRatingBar" parent="Widget.AppCompat.RatingBar">
        <item name="colorControlActivated">#FFD700</item> <!-- Gold -->
        <item name="colorControlNormal">#E0E0E0</item>     <!-- Grey -->
        <item name="colorControlHighlight">#FFD700</item>
    </style>


</resources>